+fn refresh_cached_focused_pane_title(
+    panes: &mut PaneManifest,
+    tab_position: usize,
+    pane_id: PaneId,
+    current_title: &str,
+) -> bool {
+    let Some(cached_pane) = panes.panes.get_mut(&tab_position).and_then(|panes| {
+        panes.iter_mut().find(|cached_pane| {
+            let cached_id = if cached_pane.is_plugin {
+                PaneId::Plugin(cached_pane.id)
+            } else {
+                PaneId::Terminal(cached_pane.id)
+            };
+            cached_id == pane_id
+        })
+    }) else {
+        return false;
+    };
+
+    if cached_pane.title == current_title {
+        false
+    } else {
+        cached_pane.title = current_title.to_owned();
+        true
+    }
