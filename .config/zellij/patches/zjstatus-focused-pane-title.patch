+fn refresh_cached_focused_pane(
+    panes: &mut PaneManifest,
+    tab_position: usize,
+    pane_id: PaneId,
+    mut current_pane: PaneInfo,
+) -> bool {
+    let panes_for_tab = panes.panes.entry(tab_position).or_default();
+    let mut changed = false;
+    let mut found = false;
+
+    for cached_pane in panes_for_tab.iter_mut() {
+        let cached_id = if cached_pane.is_plugin {
+            PaneId::Plugin(cached_pane.id)
+        } else {
+            PaneId::Terminal(cached_pane.id)
+        };
+        let is_current = cached_id == pane_id;
+
+        if cached_pane.is_focused != is_current {
+            cached_pane.is_focused = is_current;
+            changed = true;
+        }
+        if is_current {
+            found = true;
+            if cached_pane.title != current_pane.title {
+                cached_pane.title.clone_from(&current_pane.title);
+                changed = true;
+            }
+        }
+    }
+
+    if !found {
+        current_pane.is_focused = true;
+        panes_for_tab.push(current_pane);
+        changed = true;
+    }
+
+    changed
+}
