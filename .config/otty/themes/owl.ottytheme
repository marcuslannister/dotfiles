[meta]
name = "Owl"
mode = "dark"

[terminal]
foreground           = "#DEDEDE"
background           = "#2F2B2C"
cursor               = "#DEDEDE"
cursor-text          = "#2F2B2C"
selection-foreground = "#2F2B2C"
selection-background = "#DEDEDE"
palette = [
    "#302C2C", "#5A5A5A", "#989898", "#CACACA",
    "#656565", "#B1B1B1", "#7F7F7F", "#DEDEDE",
    "#5D595B", "#DA5B2C", "#989898", "#CACACA",
    "#656565", "#B1B1B1", "#7F7F7F", "#FFFFFF",
]
